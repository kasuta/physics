% physmotion.sty
% 物体の運動を表す図を描くためのスタイルファイル
%
% ============================================================
% コマンド一覧
% ============================================================
%
% 【等加速度運動の図】
%   \motiondiagram{初速度}{終速度}{加速度}{時刻変数}
%   例: \motiondiagram{v_0}{v}{a}{t}
%
% 【水平投射の図】
%   \projectilediagram{初速度}{水平速度}{鉛直速度}{合成速度}{重力加速度}{時刻変数}
%   例: \projectilediagram{v_0}{v_x}{v_y}{v}{g}{t}
%
% 【斜方投射の図】
%   \obliqueprojectilediagram{初速度}{仰角}{水平成分}{鉛直成分}{重力加速度}{時刻変数}
%   例: \obliqueprojectilediagram{v_0}{\theta}{v_{x0}}{v_{y0}}{g}{t}
%
% 【投げ下ろしの図】
%   \throwdowndiagram{初速度}{終速度}{加速度}{時刻変数}
%
% 【投げ上げの図】
%   \throwupdiagram{初速度}{途中速度}{重力加速度}{時刻変数}
%
% 【直角三角形】
%   \righttriangle{斜辺}{底辺}{高さ}{仰角}
%
% 【水平投射（具体値付き）】
%   \horizontalprojectilediagram{初速度}{水平速度}{鉛直速度}{高さ}
%
% 【斜方投射（シンプル版）】
%   \simpleobliqueprojectilediagram{初速度}{仰角}{水平速度}{鉛直速度}
%
% ============================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{physmotion}[2024/01/01 Physics Motion Diagram]

\RequirePackage{tikz}
\usetikzlibrary{arrows.meta}

% ============================================================
% \motiondiagram — 等加速度運動
% ============================================================
\newcommand{\motiondiagram}[4]{%
  \def\R{0.35}%
  \def\CY{\R}%
  \def\Vshort{0.9}%
  \def\Vlong{1.5}%
  \begin{tikzpicture}[
    baseline=(current bounding box.center),
    >={Stealth[length=5pt, width=4pt]}
  ]
    % x 軸
    \draw[->] (-0.7, 0) -- (7.2, 0)
      node[right] {\small $x$};

    % 左側の物体 (t=0)
    \draw[thick] (0.5, \CY) circle (\R);
    \draw (0.5, -0.1) -- (0.5, 0.1);
    \node[above=2pt] at (0.5, \CY+\R) {\small $t=0$};
    \node[below=2pt] at (0.5, 0)      {\small $O$};
    \draw[->] (0.5, \CY) -- +(\Vshort, 0)
      node[above, pos=0.75] {\small $#1$};

    % 中央の加速度矢印
    \draw[-{Stealth[length=10pt, width=10pt]}, line width=3pt]
      (2.1, \CY) -- (3.1, \CY);
    \node[above=2pt] at (2.6, \CY+0.15) {\small $#3$};

    % 右側の物体
    \draw[thick] (4.2, \CY) circle (\R);
    \draw (4.2, -0.1) -- (4.2, 0.1);
    \node[above=2pt] at (4.2, \CY+\R) {\small $t=#4$};
    \node[below=2pt] at (4.2, 0)      {\small $x$};
    \draw[->] (4.2, \CY) -- +(\Vlong, 0)
      node[above, midway] {\small $#2$};

  \end{tikzpicture}%
}

% ============================================================
% \dashedseparator — 中央に表示する破線区切り
% ============================================================
\newcommand{\dashedseparator}{%
  \par\bigskip\noindent
  \begin{center}
    \begin{tikzpicture}
      \draw[dashed, thick] (0,0) -- (\textwidth,0);
    \end{tikzpicture}
  \end{center}
  \par\bigskip
}

% ============================================================
% \projectilediagram — 水平投射
% ============================================================
\newcommand{\projectilediagram}[6]{%
  \def\Px{3.0}%
  \def\Py{2.2}%
  \def\VH{1.0}%
  \def\VV{0.85}%
  \def\R{0.18}%
  \begin{tikzpicture}[
    baseline=(current bounding box.north),
    yscale=-1,
    >={Stealth[length=5pt, width=4pt]}
  ]

    % 軸
    \draw[->] (0, 0) -- (4.25, 0) node[right] {\small $x$};
    \draw[->] (0, 0) -- (0, 3.5) node[below] {\small $y$};

    % 放物線
    \draw[dashed, thick]
      (0, 0)
      .. controls (1.2, 0) and (2.8, 1.6) ..
      (3.79, 3.5);

    % 原点の物体
    \draw[black] (0, 0) circle (\R);
    \node[above left=1pt] at (-\R, 0) {\small $t=0$};
    \draw[->, thick, red]
      (0, 0) -- (\VH, 0)
      node[above, pos=0.7] {\small $#1$};

    % 重力矢印
    \draw[-{Stealth[length=10pt, width=10pt]}, line width=3pt]
      (-0.7, 0.8) -- (-0.7, 1.7)
      node[left, midway] {\small $#5$};

    % 途中位置の物体
    \draw[black] (\Px, \Py) circle (\R);
    \node[left=2pt] at (\Px-\R, \Py) {\small $t=#6$};

    \def\VVa{1.467}%

    % 点線補助線
    \draw[dotted]
      (\Px,       \Py)         -- (\Px+\VH,  \Py);
    \draw[dotted]
      (\Px,       \Py)         -- (\Px,      \Py+\VVa);
    \draw[dotted]
      (\Px+\VH,   \Py)         -- (\Px+\VH,  \Py+\VVa);
    \draw[dotted]
      (\Px,       \Py+\VVa)    -- (\Px+\VH,  \Py+\VVa);

    % 速度ベクトル
    \draw[->, thick, red]
      (\Px, \Py) -- (\Px+\VH, \Py)
      node[above, pos=0.85] {\small $#2$};

    \draw[->, thick, green!60!black]
      (\Px, \Py) -- (\Px, \Py+\VVa)
      node[left, pos=0.85] {\small $#3$};

    \draw[->, thick, blue]
      (\Px, \Py) -- (\Px+\VH, \Py+\VVa)
      node[right] {\small $#4$};

  \end{tikzpicture}%
}

% ============================================================
% \obliqueprojectilediagram — 斜方投射
% ============================================================
\newcommand{\obliqueprojectilediagram}[6]{%
  \def\R{0.18}%
  \def\VH{0.85}%
  \def\PxA{1.363}%
  \def\PyA{1.969}%
  \def\Ptop{3.025}%
  \def\PyTop{2.625}%
  \def\PxB{4.725}%
  \def\PyB{1.969}%
  \def\VyA{0.717}%
  \def\VyB{0.684}%
  \begin{tikzpicture}[
    baseline=(current bounding box.north),
    >={Stealth[length=5pt, width=4pt]}
  ]

    % 軸
    \draw[->] (-0.2, 0) -- (6.8, 0) node[right] {\small $x$};
    \draw[->] (0, -0.2) -- (0, 3.8) node[above] {\small $y$};

    % 放物線
    \draw[dashed, thick]
      (0, 0)
      .. controls (1.5, 3.5) and (4.5, 3.5) ..
      (6.2, 0);

    % 原点の物体
    \draw[black] (0, 0) circle (\R);

    % 初速度
    \def\Voy{1.983}%
    \draw[->, thick, blue]
      (0, 0) -- (\VH, \Voy)
      node[left=4pt, pos=1.0] {\small $#1$};

    % 仰角の弧
    \draw[->] (0.40, 0) arc[start angle=0, end angle=67, radius=0.40];
    \node[right=2pt] at (0.42, 0.26) {\small $\theta$：仰角};

    % 速度成分
    \draw[->, thick, orange]
      (0, 0) -- (\VH, 0)
      node[below, pos=0.6] {\small $#3$};

    \draw[->, thick, green!60!black]
      (0, 0) -- (0, \Voy)
      node[left, pos=0.6] {\small $#4$};

    % 点線補助
    \draw[dotted] (\VH, 0) -- (\VH, \Voy);
    \draw[dotted] (0, \Voy) -- (\VH, \Voy);

    % 重力矢印
    \draw[-{Stealth[length=8pt, width=8pt]}, line width=2.5pt, red]
      (6.55, 2.6) -- (6.55, 1.6)
      node[right, pos=0.5] {\small $#5$};

    % 最高点
    \draw[black] (\Ptop, \PyTop) circle (\R);
    \node[above=3pt] at (\Ptop, \PyTop+\R)
      {\small 最高点};

    \draw[->, thick, orange]
      (\Ptop, \PyTop) -- (\Ptop+\VH, \PyTop)
      node[above, pos=0.6] {\small $v_x$};

    % 上昇中の途中位置
    \draw[black] (\PxA, \PyA) circle (\R);

    \draw[->, thick, orange]
      (\PxA, \PyA) -- (\PxA+\VH, \PyA)
      node[below, pos=0.75] {\small $v_x$};

    \draw[->, thick, green!60!black]
      (\PxA, \PyA) -- (\PxA, \PyA+\VyA)
      node[left, pos=0.6] {\small $v_y$};

    \draw[->, thick, blue]
      (\PxA, \PyA) -- (\PxA+\VH, \PyA+\VyA)
      node[right=1pt] {\small $v$};

    % 点線補助
    \draw[dotted] (\PxA+\VH, \PyA) -- (\PxA+\VH, \PyA+\VyA);
    \draw[dotted] (\PxA, \PyA+\VyA) -- (\PxA+\VH, \PyA+\VyA);

    % 下降中の途中位置
    \draw[black] (\PxB, \PyB) circle (\R);

    \draw[->, thick, orange]
      (\PxB, \PyB) -- (\PxB+\VH, \PyB)
      node[above, pos=0.75] {\small $v_x$};

    \draw[->, thick, green!60!black]
      (\PxB, \PyB) -- (\PxB, \PyB-\VyB)
      node[left, pos=0.6] {\small $v_y$};

    \draw[->, thick, blue]
      (\PxB, \PyB) -- (\PxB+\VH, \PyB-\VyB)
      node[right=1pt] {\small $v$};

    % 点線補助
    \draw[dotted] (\PxB+\VH, \PyB) -- (\PxB+\VH, \PyB-\VyB);
    \draw[dotted] (\PxB, \PyB-\VyB) -- (\PxB+\VH, \PyB-\VyB);

  \end{tikzpicture}%
}

% ============================================================
% \throwdowndiagram — 投げ下ろし
% ============================================================
\newcommand{\throwdowndiagram}[4]{%
  \def\R{0.35}%
  \def\CX{0.5}%
  \def\AX{-0.6}%
  \def\YtopC{0.4}%
  \def\YbotC{3.0}%
  \def\Vshort{0.9}%
  \def\Vlong{1.5}%
  \begin{tikzpicture}[
    baseline=(current bounding box.north),
    yscale=-1,
    >={Stealth[length=5pt, width=4pt]}
  ]
    % y 軸
    \draw[->] (\AX, -0.7) -- (\AX, 5.5)
      node[below] {\small $y$};

    % 上側の物体
    \draw[dotted] (\AX, \YtopC) -- (\CX, \YtopC);
    \draw (\AX-0.1, \YtopC) -- (\AX+0.1, \YtopC);
    \node[left=2pt] at (\AX, \YtopC) {\small $O$};
    \draw[thick] (\CX, \YtopC) circle (\R);
    \node[right=2pt] at (\CX+\R, \YtopC) {\small $t=0$};
    \draw[->] (\CX, \YtopC) -- ++(0, \Vshort)
      node[right, pos=0.75] {\small $#1$};

    % 加速度矢印
    \draw[-{Stealth[length=10pt, width=10pt]}, line width=3pt]
      (1.2, 1.55) -- (1.2, 2.15);
    \node[right=6pt] at (1.2, 1.85) {\small $#3$};

    % 下側の物体
    \draw[dotted] (\AX, \YbotC) -- (\CX, \YbotC);
    \draw (\AX-0.1, \YbotC) -- (\AX+0.1, \YbotC);
    \node[left=2pt] at (\AX, \YbotC) {\small $y$};
    \draw[thick] (\CX, \YbotC) circle (\R);
    \node[right=2pt] at (\CX+\R, \YbotC) {\small $t=#4$};
    \draw[->] (\CX, \YbotC) -- ++(0, \Vlong)
      node[right, midway] {\small $#2$};

  \end{tikzpicture}%
}

% ============================================================
% \throwupdiagram — 投げ上げ
% ============================================================
\newcommand{\throwupdiagram}[4]{%
  \def\R{0.35}%
  \def\AX{0.0}%
  \def\UX{0.9}%
  \def\TX{1.42}%
  \def\DX{1.95}%
  \def\YbotC{0.5}%
  \def\YmidC{2.9}%
  \def\YtopC{3.8}%
  \def\YdownC{1.7}%
  \def\Vbot{1.0}%
  \def\Vmid{0.5}%
  \def\Vdown{0.75}%
  \begin{tikzpicture}[
    baseline=(current bounding box.north),
    >={Stealth[length=5pt, width=4pt]}
  ]
    % y 軸
    \draw[->] (\AX, -0.3) -- (\AX, 5.8)
      node[above] {\small $y$};

    % 重力矢印
    \draw[-{Stealth[length=10pt, width=10pt]}, line width=3pt]
      (\AX-0.55, 4.2) -- (\AX-0.55, 3.2);
    \node[left=3pt] at (\AX-0.55, 3.7) {\small $#3$};

    % 軌跡の破線
    \draw[dashed, thick]
      (\UX, -0.3) -- (\UX, \YtopC);
    \draw[dashed, thick]
      (\UX, \YtopC) arc[start angle=180, end angle=0,
        x radius={(\DX-\UX)/2}, y radius=0.7];
    \draw[->, dashed, thick]
      (\DX, \YtopC) -- (\DX, -0.3);

    % t=0 の物体
    \draw (\AX-0.08, \YbotC) -- (\AX+0.08, \YbotC);
    \node[left=2pt] at (\AX, \YbotC) {\small $O$};
    \draw[thick] (\UX, \YbotC) circle (\R);
    \draw[->, thick] (\UX, \YbotC) -- ++(0, \Vbot)
      node[right, pos=0.7] {\small $#1$};

    % 上昇途中の物体
    \draw (\AX-0.08, \YmidC) -- (\AX+0.08, \YmidC);
    \node[left=2pt] at (\AX, \YmidC) {\small $y$};
    \draw[thick] (\UX, \YmidC) circle (\R);
    \draw[->, thick] (\UX, \YmidC) -- ++(0, \Vmid)
      node[right, pos=0.7] {\small $#2$};

    % 最高点
    \draw (\AX-0.08, \YtopC+0.7) -- (\AX+0.08, \YtopC+0.7);
    \draw[thick] (\TX, \YtopC+0.7) circle (\R);
    \node[above=3pt] at (\TX, \YtopC+0.7+\R) {\small 最高点：$v=0$};

    % 下降中の物体
    \draw[thick] (\DX, \YdownC) circle (\R);
    \draw[->, thick] (\DX, \YdownC) -- ++(0, -\Vdown)
      node[right, pos=0.7] {\small $#2$};

  \end{tikzpicture}%
}

% ============================================================
% \righttriangle — 直角三角形
% ============================================================
\newcommand{\righttriangle}[4]{%
  \def\W{3.2}%
  \def\H{2.0}%
  \def\AR{0.3}%
  \def\AN{0.5}%
  \begin{tikzpicture}[
    baseline=(current bounding box.center),
    >={Stealth[length=5pt, width=4pt]}
  ]
    % 三角形の三辺
    \draw[thick] (0, 0) -- (\W, 0) -- (\W, \H) -- cycle;

    % 直角マーク
    \draw (\W-\AR, 0) -- (\W-\AR, \AR) -- (\W, \AR);

    % 仰角の弧
    \draw ({\AN*cos(32)}, {\AN*sin(32)})
      arc[start angle=32, end angle=0, radius=\AN];
    \node at (0.62, 0.18) {\small $#4$};

    % ラベル
    \node[above left=1pt] at ({\W/2}, {\H/2}) {\small $#1$};
    \node[below=3pt] at ({\W/2}, 0) {\small $#2$};
    \node[right=3pt] at (\W, {0.5*\H}) {\small $#3$};

  \end{tikzpicture}%
}

% ============================================================
% \horizontalprojectilediagram — 水平投射（具体値付き）
% ============================================================
\newcommand{\horizontalprojectilediagram}[4]{%
  \def\R{0.35}%
  \def\GH{-5.0}%
  \def\VH{1.5}%
  \def\VV{1.5}%
  \def\Px{3.8}%
  \def\Py{-2.6}%
  \begin{tikzpicture}[
    baseline=(current bounding box.north),
    >={Stealth[length=5pt, width=4pt]}
  ]

    % 座標軸
    \draw[->, thick] (-0.5, 0) -- (8.5, 0) node[right] {\small $x$};
    \draw[->, thick] (0, 0.5) -- (0, -6.5) node[below] {\small $y$};

    % 地面
    \draw[thick] (0, \GH) -- (8.5, \GH);
    \foreach \hx in {0.3, 0.9, 1.5, 2.1, 2.7, 3.3, 3.9, 4.5, 5.1, 5.7, 6.3, 6.9, 7.5, 8.1}{%
      \draw[thin] (\hx, \GH) -- (\hx - 0.3, \GH - 0.35);%
    }
    \node[below=4pt] at (4.5, \GH) {\small 地面};

    % 高さ両矢印
    \draw[<->, red, thick] (-0.5, 0) -- (-0.5, \GH);
    \node[red, left=4pt] at (-0.5, -2.5) {\small $#4$};

    % 原点の球
    \draw[thick] (0, 0) circle (\R);

    % 初速度矢印
    \draw[->, red, thick] (0, 0) -- (\VH, 0)
      node[above, pos=0.6] {\small $#1$};

    % 放物線
    \draw[dashed, thick]
      (0, 0) .. controls (2.5, -0.5) and (4.0, -2.5) .. (5.5, \GH);

    % 途中の球
    \draw[thick] (\Px, \Py) circle (\R);

    % 速度ベクトル
    \draw[->, thick] (\Px, \Py) -- (\Px + \VH, \Py)
      node[above, pos=0.75] {\small $#2$};

    \draw[->, thick] (\Px, \Py) -- (\Px, \Py - \VV)
      node[right, pos=0.75] {\small $#3$};

  \end{tikzpicture}%
}

% ============================================================
% \simpleobliqueprojectilediagram — 斜方投射（シンプル版）
% ============================================================
\newcommand{\simpleobliqueprojectilediagram}[4]{%
  \begin{tikzpicture}[
    x=1.0cm, y=2.0cm,
    baseline=(current bounding box.center),
    >={Stealth[length=5pt, width=4pt]},
    thick
  ]

    % 座標軸
    \draw[->, thick] (-0.5, 0) -- (9.5, 0) node[right] {\small $x$};
    \draw[->, thick] (0, -0.15) -- (0, 1.0) node[above] {\small $y$};

    % 放物線
    \draw[dashed, thick]
      (0, 0)
      .. controls (2.0, 0.5774) and (6.0, 0.5774) ..
      (8.0, 0);

    % 原点の球
    \draw[thick] (0, 0) ellipse[x radius=0.22, y radius=0.11];

    % 初速度矢印
    \draw[->, red, thick] (0, 0) -- (0.9608, 0.2774);
    \node[red, above=3pt] at (0.48, 0.2774) {\small $#1$};

    % 仰角の弧
    \draw[red]
      (0.75, 0) arc[x radius=0.75, y radius=0.375, start angle=0, end angle=30];
    \node[red, right=2pt] at (0.84, 0.08) {\small $#2^\circ$};

    % 最高点の球
    \draw[thick] (4.0, 0.4331) ellipse[x radius=0.22, y radius=0.11];
    \draw[->, thick] (4.0, 0.4331) -- (4.95, 0.4331)
      node[above=2pt, pos=0.8] {\small $#3$};

    % 下降中の球
    \draw[thick] (6.0, 0.3434) ellipse[x radius=0.22, y radius=0.11];
    \draw[->, thick] (6.0, 0.3434) -- (6.95, 0.3434)
      node[above=2pt, pos=0.8] {\small $#3$};
    \draw[->, thick] (6.0, 0.3434) -- (6.0, 0.0434)
      node[right=3pt, pos=0.6] {\small $#4$};

  \end{tikzpicture}%
}

